<div class="box">
  <h1 class="title">Welcome to BandSeeking</h1>

  <%= render 'filters' %>

  <% if @bands.any? %>
    <div class="bands-grid">
      <% @bands.each do |band| %>
        <div class="box band-card">
          <% if band.header_image.attached? %>
            <div class="band-card-image">
              <%= image_tag band.header_image %>
            </div>
          <% end %>
          
          <h2 class="subtitle"><%= link_to band.name, band_path(band) %></h2>
          
          <p class="location">
            <strong><%= "#{band.city}, #{band.state}" %></strong>
          </p>

          <div class="tags">
            <% band.seeking_instruments.each do |instrument| %>
              <span class="tag"><%= instrument.titleize %></span>
            <% end %>
          </div>

          <div class="band-card-links">
            <% if band.instagram_handle.present? %>
              <%= link_to "Instagram", "https://instagram.com/#{band.instagram_handle}", class: "button is-small", target: "_blank" %>
            <% end %>
            
            <% if band.website_url.present? %>
              <%= link_to "Website", band.website_url, class: "button is-small", target: "_blank" %>
            <% end %>
            
            <% if band.bandcamp_url.present? %>
              <%= link_to "Bandcamp", band.bandcamp_url, class: "button is-small", target: "_blank" %>
            <% end %>
          </div>

          <%= link_to 'View Details', band_path(band), class: "button neon-button is-fullwidth mt-3" %>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="has-text-centered">No bands found matching your filters.</p>
  <% end %>
</div> 