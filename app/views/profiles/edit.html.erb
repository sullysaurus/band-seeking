<div class="box">
  <h1 class="title">Edit Profile</h1>

  <%= form_with(model: @user, url: profile_path, local: true) do |f| %>
    <% if @user.errors.any? %>
      <div class="notification is-danger">
        <h2><%= pluralize(@user.errors.count, "error") %> prohibited this profile from being saved:</h2>
        <ul>
          <% @user.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="field">
      <%= f.label :avatar, class: "label" %>
      <div class="control">
        <%= f.file_field :avatar, class: "input" %>
      </div>
    </div>

    <div class="field">
      <%= f.label :instruments_played, "Instruments You Play", class: "label" %>
      <div class="control">
        <div class="checkboxes-grid">
          <%= f.collection_check_boxes :instruments_played, Band::INSTRUMENTS.map { |i| [i, i.titleize] }, :first, :second do |b| %>
            <div class="checkbox-item">
              <%= b.check_box %>
              <%= b.label %>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <div class="field">
      <%= f.label :looking_for, "Looking For", class: "label" %>
      <div class="control">
        <%= f.select :looking_for, 
          User::LOOKING_FOR,
          { include_blank: "Select Band Type" },
          { class: "input" }
        %>
      </div>
    </div>

    <div class="field">
      <%= f.label :city, class: "label" %>
      <div class="control">
        <%= f.text_field :city, class: "input", placeholder: "Enter city name" %>
      </div>
    </div>

    <div class="field">
      <%= f.label :state, class: "label" %>
      <div class="control">
        <%= f.select :state, 
          [
            ['Alabama', 'AL'], ['Alaska', 'AK'], ['Arizona', 'AZ'], ['Arkansas', 'AR'], ['California', 'CA'],
            ['Colorado', 'CO'], ['Connecticut', 'CT'], ['Delaware', 'DE'], ['Florida', 'FL'], ['Georgia', 'GA'],
            ['Hawaii', 'HI'], ['Idaho', 'ID'], ['Illinois', 'IL'], ['Indiana', 'IN'], ['Iowa', 'IA'],
            ['Kansas', 'KS'], ['Kentucky', 'KY'], ['Louisiana', 'LA'], ['Maine', 'ME'], ['Maryland', 'MD'],
            ['Massachusetts', 'MA'], ['Michigan', 'MI'], ['Minnesota', 'MN'], ['Mississippi', 'MS'], ['Missouri', 'MO'],
            ['Montana', 'MT'], ['Nebraska', 'NE'], ['Nevada', 'NV'], ['New Hampshire', 'NH'], ['New Jersey', 'NJ'],
            ['New Mexico', 'NM'], ['New York', 'NY'], ['North Carolina', 'NC'], ['North Dakota', 'ND'], ['Ohio', 'OH'],
            ['Oklahoma', 'OK'], ['Oregon', 'OR'], ['Pennsylvania', 'PA'], ['Rhode Island', 'RI'], ['South Carolina', 'SC'],
            ['South Dakota', 'SD'], ['Tennessee', 'TN'], ['Texas', 'TX'], ['Utah', 'UT'], ['Vermont', 'VT'],
            ['Virginia', 'VA'], ['Washington', 'WA'], ['West Virginia', 'WV'], ['Wisconsin', 'WI'], ['Wyoming', 'WY']
          ],
          { include_blank: "Select State" },
          { class: "input" }
        %>
      </div>
    </div>

    <div class="field">
      <%= f.label :instagram_handle, class: "label" %>
      <div class="control">
        <%= f.text_field :instagram_handle, class: "input", placeholder: "yourusername (no @ symbol)" %>
      </div>
      <p class="help">Just the username, no @ symbol needed</p>
    </div>

    <div class="field">
      <%= f.label :website_url, class: "label" %>
      <div class="control">
        <%= f.text_field :website_url, class: "input", placeholder: "https://yourwebsite.com" %>
      </div>
    </div>

    <div class="field">
      <%= f.label :spotify_embed, "Spotify Embed Code", class: "label" %>
      <div class="control">
        <%= f.text_area :spotify_embed, class: "input", rows: 3, 
            placeholder: "Paste your Spotify embed code here" %>
      </div>
      <p class="help">Go to Spotify, click share on your artist profile, click embed, and paste the code here</p>
    </div>

    <div class="field">
      <%= f.label :youtube_embed, "YouTube Embed Code", class: "label" %>
      <div class="control">
        <%= f.text_area :youtube_embed, class: "input", rows: 3,
            placeholder: "Paste your YouTube embed code here" %>
      </div>
      <p class="help">Go to YouTube, click share on your video, click embed, and paste the code here</p>
    </div>

    <div class="actions">
      <%= f.submit "Update Profile", class: "button neon-button" %>
      <%= link_to "Back to Profile", profile_path, class: "button" %>
    </div>
  <% end %>
</div> 