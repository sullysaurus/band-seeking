<div class="box">
  <div class="columns">
    <div class="column is-one-quarter">
      <% if @user.avatar.attached? %>
        <%= image_tag @user.avatar %>
      <% end %>
    </div>
    
    <div class="column">
      <h1 class="title"><%= @user.email %></h1>
      
      <div class="content">
        <% if @user.instruments_played.present? %>
          <p><strong>Plays:</strong> <%= @user.instruments_played_list %></p>
        <% end %>
        
        <% if @user.looking_for.present? %>
          <p><strong>Looking For:</strong> <%= @user.looking_for %></p>
        <% end %>
        
        <% if @user.city.present? || @user.state.present? %>
          <p><strong>Location:</strong> <%= [@user.city, @user.state].compact.join(", ") %></p>
        <% end %>
        
        <% if @user.instagram_handle.present? %>
          <p>
            <strong>Instagram:</strong>
            <%= link_to "@#{@user.instagram_handle}", "https://instagram.com/#{@user.instagram_handle}" %>
          </p>
        <% end %>
        
        <% if @user.website_url.present? %>
          <p>
            <strong>Website:</strong>
            <%= link_to @user.website_url, @user.website_url %>
          </p>
        <% end %>
      </div>

      <%= link_to "Edit Profile", edit_profile_path, class: "button neon-button" %>
    </div>
  </div>

  <% if @user.spotify_embed.present? %>
    <div class="mt-6">
      <h2 class="title is-4">Music</h2>
      <%= @user.spotify_embed.html_safe %>
    </div>
  <% end %>

  <% if @user.youtube_embed.present? %>
    <div class="mt-6">
      <h2 class="title is-4">Videos</h2>
      <%= @user.youtube_embed.html_safe %>
    </div>
  <% end %>

  <div class="bands-section">
    <h3 class="subtitle">My Bands</h3>
    
    <% if current_user == @profile.user %>
      <div class="buttons">
        <%= link_to 'Create New Band', new_band_path, class: 'button neon-button' %>
      </div>
    <% end %>

    <% if @profile.user.bands.any? %>
      <div class="bands-grid">
        <% @profile.user.bands.each do |band| %>
          <div class="box band-card">
            <h2 class="subtitle"><%= link_to band.name, band_path(band) %></h2>
            <p><%= "#{band.city}, #{band.state}" %></p>
            <div class="tags">
              <% band.seeking_instruments.each do |instrument| %>
                <span class="tag"><%= instrument.titleize %></span>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="no-bands">No bands created yet.</p>
    <% end %>
  </div>
</div> 