<%= form_with(model: band, local: true, data: { controller: "image-cropper" }) do |f| %>
  <% if band.errors.any? %>
    <div class="notification is-danger">
      <h2><%= pluralize(band.errors.count, "error") %> prohibited this band from being saved:</h2>
      <ul>
        <% band.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= f.label :header_image, class: "label" %>
    <div class="control">
      <%= f.file_field :header_image, class: "input", accept: 'image/png,image/jpeg', direct_upload: true, data: { action: "change->image-cropper#preview" } %>
      <%= f.hidden_field :cropped_image_data %>
    </div>
    <% if band.header_image.attached? %>
      <div class="mt-2">
        <p>Current image:</p>
        <%= image_tag band.header_image, class: "preview-image" %>
      </div>
    <% end %>
    <p class="help">Maximum file size: 5MB. Supported formats: PNG, JPEG</p>
  </div>

  <div class="field">
    <%= f.label :name, class: "label" %>
    <div class="control">
      <%= f.text_field :name, class: "input" %>
    </div>
  </div>

  <div class="field">
    <%= f.label :band_type, "Band Type", class: "label" %>
    <div class="control">
      <%= f.select :band_type, Band::BAND_TYPES, { include_blank: "Select Band Type" }, { class: "input" } %>
    </div>
  </div>

  <div class="field">
    <%= f.label :city, class: "label" %>
    <div class="control">
      <%= f.text_field :city, class: "input" %>
    </div>
  </div>

  <div class="field">
    <%= f.label :state, class: "label" %>
    <div class="control">
      <%= f.select :state, 
        [
          ['Alabama', 'AL'], ['Alaska', 'AK'], ['Arizona', 'AZ'], ['Arkansas', 'AR'], ['California', 'CA'],
          ['Colorado', 'CO'], ['Connecticut', 'CT'], ['Delaware', 'DE'], ['Florida', 'FL'], ['Georgia', 'GA'],
          ['Hawaii', 'HI'], ['Idaho', 'ID'], ['Illinois', 'IL'], ['Indiana', 'IN'], ['Iowa', 'IA'],
          ['Kansas', 'KS'], ['Kentucky', 'KY'], ['Louisiana', 'LA'], ['Maine', 'ME'], ['Maryland', 'MD'],
          ['Massachusetts', 'MA'], ['Michigan', 'MI'], ['Minnesota', 'MN'], ['Mississippi', 'MS'], ['Missouri', 'MO'],
          ['Montana', 'MT'], ['Nebraska', 'NE'], ['Nevada', 'NV'], ['New Hampshire', 'NH'], ['New Jersey', 'NJ'],
          ['New Mexico', 'NM'], ['New York', 'NY'], ['North Carolina', 'NC'], ['North Dakota', 'ND'], ['Ohio', 'OH'],
          ['Oklahoma', 'OK'], ['Oregon', 'OR'], ['Pennsylvania', 'PA'], ['Rhode Island', 'RI'], ['South Carolina', 'SC'],
          ['South Dakota', 'SD'], ['Tennessee', 'TN'], ['Texas', 'TX'], ['Utah', 'UT'], ['Vermont', 'VT'],
          ['Virginia', 'VA'], ['Washington', 'WA'], ['West Virginia', 'WV'], ['Wisconsin', 'WI'], ['Wyoming', 'WY']
        ],
        { include_blank: "Select State" },
        { class: "input" }
      %>
    </div>
  </div>

  <div class="field">
    <%= f.label :seeking_instruments, "Seeking", class: "label" %>
    <div class="control">
      <div class="checkboxes-grid">
        <%= f.collection_check_boxes :seeking_instruments, Band::INSTRUMENTS.map { |i| [i, i.titleize] }, :first, :second do |b| %>
          <div class="checkbox-item">
            <%= b.check_box %>
            <%= b.label %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="field">
    <%= f.label :instagram_handle, class: "label" %>
    <div class="control">
      <%= f.text_field :instagram_handle, class: "input", placeholder: "yourusername (no @ symbol)" %>
    </div>
    <p class="help">Just the username, no @ symbol needed</p>
  </div>

  <div class="field">
    <%= f.label :website_url, class: "label" %>
    <div class="control">
      <%= f.text_field :website_url, class: "input", placeholder: "https://yourwebsite.com" %>
    </div>
  </div>

  <div class="field">
    <%= f.label :bandcamp_url, class: "label" %>
    <div class="control">
      <%= f.text_field :bandcamp_url, class: "input", placeholder: "https://yourbandname.bandcamp.com" %>
    </div>
  </div>

  <div class="field">
    <%= f.label :spotify_url, class: "label" %>
    <div class="control">
      <%= f.text_field :spotify_url, class: "input", placeholder: "https://open.spotify.com/artist/..." %>
    </div>
    <p class="help">Full Spotify URL to your artist page</p>
  </div>

  <div class="field">
    <%= f.label :songkick_id, class: "label" %>
    <div class="control">
      <%= f.text_field :songkick_id, class: "input" %>
    </div>
    <p class="help">Your Songkick artist ID number</p>
  </div>

  <div class="field">
    <%= f.label :bandsintown_id, class: "label" %>
    <div class="control">
      <%= f.text_field :bandsintown_id, class: "input" %>
    </div>
    <p class="help">Use your exact artist name from Bandsintown</p>
  </div>

  <div class="field">
    <%= f.label :youtube_url, "YouTube Video URL", class: "label" %>
    <div class="control">
      <%= f.text_field :youtube_url, class: "input" %>
    </div>
  </div>

  <div class="field">
    <%= f.submit class: "button is-fullwidth neon-button" %>
  </div>
<% end %>

<%= render 'image_cropper_modal' %> 